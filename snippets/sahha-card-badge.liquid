{%- comment -%}
  Sahha Daily marketing badge for product cards (shop / collection grids).
  Reads the `custom.badge` metafield (e.g. "Best seller", "New", "Popular").
  Renders nothing when the metafield is empty, so it is safe pre-import.

  Usage: {% render 'sahha-card-badge', card_product: card_product %}
{%- endcomment -%}
{%- liquid
  assign sahha_badge = card_product.metafields.custom.badge.value
-%}
{%- if sahha_badge != blank -%}
  <span class="badge sahha-badge badge--top-left">{{ sahha_badge }}</span>
{%- endif -%}
