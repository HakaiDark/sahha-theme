{% comment %}
  Renders a product card — Sahha editorial ".pcard" (matches www.sahhadaily.com).
  Replaces Dawn's default card markup with the live site's structure:
  media · overlay link · body (two-cat meta · title · stars+count+badge · price+View).
  Styles live in assets/sahha-brand.css (".pcard*", ported from the live CSS, rem ×1.6).

  Accepts:
  - card_product: {Object} Product Liquid object (optional)
  - media_aspect_ratio, image_shape, show_secondary_image, show_vendor, show_rating,
    extend_height, lazy_load, skip_styles, quick_add, section_id, horizontal_class,
    horizontal_quick_add: accepted for Dawn compatibility; not all are used by this design.
  - placeholder_image: {String} Placeholder used when no product exists. Default 'product-apparel-2'.

  Usage:
  {% render 'card-product', card_product: card_product %}
{% endcomment %}
{%- if card_product and card_product != empty -%}
  <div class="card-wrapper product-card-wrapper">
    <article class="pcard">
      <div class="pcard-media">
        {%- if card_product.featured_media -%}
          {% comment %}theme-check-disable ImgLazyLoading{% endcomment %}
          <img
            srcset="
              {%- if card_product.featured_media.width >= 165 -%}{{ card_product.featured_media | image_url: width: 165 }} 165w,{%- endif -%}
              {%- if card_product.featured_media.width >= 360 -%}{{ card_product.featured_media | image_url: width: 360 }} 360w,{%- endif -%}
              {%- if card_product.featured_media.width >= 533 -%}{{ card_product.featured_media | image_url: width: 533 }} 533w,{%- endif -%}
              {%- if card_product.featured_media.width >= 720 -%}{{ card_product.featured_media | image_url: width: 720 }} 720w,{%- endif -%}
              {%- if card_product.featured_media.width >= 940 -%}{{ card_product.featured_media | image_url: width: 940 }} 940w,{%- endif -%}
              {{ card_product.featured_media | image_url }} {{ card_product.featured_media.width }}w
            "
            src="{{ card_product.featured_media | image_url: width: 533 }}"
            sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 130 | divided_by: 4 }}px, (min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
            alt="{{ card_product.featured_media.alt | escape }}"
            width="{{ card_product.featured_media.width }}"
            height="{{ card_product.featured_media.height }}"
            {% unless lazy_load == false %}loading="lazy"{% endunless %}
          >
          {% comment %}theme-check-enable ImgLazyLoading{% endcomment %}
        {%- else -%}
          {{ placeholder_image | default: 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>

      <a
        class="pcard-link"
        href="{{ card_product.url }}"
        aria-label="{{ card_product.title | escape }}"
      ></a>

      <div class="pcard-body">
        <div class="pcard-meta">
          {%- if card_product.type != blank -%}
            <span class="pcard-cat">{{ card_product.type | escape }}</span>
          {%- endif -%}
          {%- assign sahha_format = card_product.metafields.custom.format.value -%}
          {%- if sahha_format != blank -%}
            <span class="pcard-cat pcard-cat--muted">{{ sahha_format | escape }}</span>
          {%- endif -%}
        </div>

        <h3 class="pcard-titlelink">{{ card_product.title | escape }}</h3>

        <div class="rrow">
          {%- assign sahha_rating = card_product.metafields.custom.rating.value -%}
          {%- if sahha_rating != blank -%}
            {%- assign sahha_pct = sahha_rating | times: 20.0 -%}
            <span class="stars" role="img" aria-label="{{ sahha_rating }} out of 5" title="{{ sahha_rating }} / 5">
              <span class="stars-empty" aria-hidden="true">★★★★★</span>
              <span class="stars-fill" aria-hidden="true" style="width: {{ sahha_pct }}%;">★★★★★</span>
            </span>
            {%- assign sahha_reviews = card_product.metafields.custom.review_count.value -%}
            {%- if sahha_reviews != blank -%}
              <span class="rcount">({{ sahha_reviews }})</span>
            {%- endif -%}
          {%- endif -%}

          {%- if card_product.available == false -%}
            <span class="tag inline lowStock">{{ 'products.product.sold_out' | t }}</span>
          {%- else -%}
            {%- assign sahha_badge = card_product.metafields.custom.badge.value -%}
            {%- if sahha_badge != blank -%}
              {%- assign sahha_badge_key = sahha_badge | downcase -%}
              {%- assign sahha_badge_cls = 'new' -%}
              {%- if sahha_badge_key contains 'best' -%}
                {%- assign sahha_badge_cls = 'bestSeller' -%}
              {%- elsif sahha_badge_key contains 'popular' -%}
                {%- assign sahha_badge_cls = 'popular' -%}
              {%- elsif sahha_badge_key contains 'low' -%}
                {%- assign sahha_badge_cls = 'lowStock' -%}
              {%- elsif sahha_badge_key contains 'new' -%}
                {%- assign sahha_badge_cls = 'new' -%}
              {%- endif -%}
              <span class="tag inline {{ sahha_badge_cls }}">{{ sahha_badge }}</span>
            {%- endif -%}
          {%- endif -%}
        </div>

        <div class="pcard-foot">
          <span class="pcard-price">
            {%- if card_product.price_varies -%}
              {{ 'products.product.price.from_price_html' | t: price: card_product.price_min | money }}
            {%- else -%}
              {{ card_product.price | money }}
            {%- endif -%}
          </span>
          <span class="alink" aria-hidden="true">
            <span class="ln">{{ 'products.product.view_full_details' | t | split: ' ' | first }}</span>
            <svg viewBox="0 0 24 24" fill="none" width="15" height="15">
              <path
                d="M5 12h14M13 6l6 6-6 6"
                stroke="currentColor"
                stroke-width="1.7"
                stroke-linecap="round"
                stroke-linejoin="round"
              ></path>
            </svg>
          </span>
        </div>
      </div>
    </article>
  </div>
{%- else -%}
  <div class="card-wrapper product-card-wrapper">
    <article class="pcard">
      <div class="pcard-media">
        {{ placeholder_image | default: 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
      </div>
      <div class="pcard-body">
        <div class="pcard-meta">
          <span class="pcard-cat">{{ 'products.product.vendor' | t }}</span>
        </div>
        <h3>{{ 'onboarding.product_title' | t }}</h3>
        <div class="pcard-foot">
          <span class="pcard-price">{{ 1999 | money }}</span>
        </div>
      </div>
    </article>
  </div>
{%- endif -%}
