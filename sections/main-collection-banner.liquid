{% comment %}
  Sahha shop hero — editorial banner that matches the live site's `.shop-hero`
  (kicker · big Playfair heading · Arabic flourish · lead). Heading + lead are
  driven by the collection so it works on every collection page; kicker/Arabic
  line are editable in the theme editor. See migration/PROJECT_STATUS.md.
{% endcomment %}

<div class="sahha-shop-hero color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width">
    <div class="sahha-shop-hero__inner{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
      {%- if section.settings.kicker != blank -%}
        {%- assign kicker_words = section.settings.kicker | split: ' ' -%}
        <span class="sahha-kicker center">
          {%- for word in kicker_words -%}
            {%- if forloop.last and kicker_words.size > 1 -%}<em>{{ word }}</em>{%- else -%}{{ word }}{%- endif -%}
            {%- unless forloop.last %}&nbsp;{% endunless -%}
          {%- endfor -%}
        </span>
      {%- endif -%}

      <h1 class="sahha-shop-hero__title">
        <span class="visually-hidden">{{ 'sections.collection_template.title' | t }}: </span>
        Shop <em>{{ collection.title | escape }}</em>
      </h1>

      {%- if section.settings.arabic_line != blank -%}
        {%- assign arabic_words = section.settings.arabic_line | split: ' ' -%}
        <p class="sahha-shop-hero__ar" dir="rtl">
          {%- for word in arabic_words -%}
            {%- if forloop.index == 2 -%}<em>{{ word }}</em>{%- else -%}{{ word }}{%- endif -%}
            {%- unless forloop.last %}&nbsp;{% endunless -%}
          {%- endfor -%}
        </p>
      {%- endif -%}

      {%- if section.settings.show_collection_description and collection.description != blank -%}
        <div class="sahha-shop-hero__lead rte">{{ collection.description }}</div>
      {%- elsif section.settings.lead != blank -%}
        <p class="sahha-shop-hero__lead">{{ section.settings.lead }}</p>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-collection-banner.name",
  "class": "section sahha-shop-banner sahha-wide",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.main-collection-banner.settings.paragraph.content"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Product catalog"
    },
    {
      "type": "text",
      "id": "arabic_line",
      "label": "Arabic flourish (leave blank to hide)",
      "default": "مكمّلات أصلية من أوروبا 🌿"
    },
    {
      "type": "text",
      "id": "lead",
      "label": "Fallback lead (used when the collection has no description)",
      "default": "Premium European-sourced wellness, delivered straight to your door."
    },
    {
      "type": "checkbox",
      "id": "show_collection_description",
      "default": true,
      "label": "t:sections.main-collection-banner.settings.show_collection_description.label"
    },
    {
      "type": "checkbox",
      "id": "show_collection_image",
      "default": false,
      "label": "t:sections.main-collection-banner.settings.show_collection_image.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    }
  ]
}
{% endschema %}

