{%- comment -%}
  Sahha Daily product FAQ — ports the live site's "Questions about this product"
  block (page.tsx `.faq-wrap`/`.pfaq` + globals.css `.faq-*`). Sits on the product
  template after related-products. Sticky intro on the left, accordion of Q&As on
  the right. Answers are built from the product's custom.* metafields (how to use,
  ingredients, safety, why use, wellness goals) plus two store-wide answers
  (ordering/COD + authenticity) set in the section settings.
  REM ×1.6 for Dawn's 10px root; px/vw/% unchanged. See memory design-port-sahha.
{%- endcomment -%}

{%- liquid
  assign m = product.metafields.custom
  assign how = m.how_to_use.value
  assign ingredients = m.ingredients.value
  assign safety = m.safety.value
  assign why = m.why_use.value
  assign goals = m.wellness_goals.value
  assign short_title = product.title | truncatewords: 3, ''

  assign goal_labels = ''
  for g in goals
    assign gl = g.short_label.value | default: g.label.value
    if forloop.first
      assign goal_labels = gl
    else
      assign goal_labels = goal_labels | append: ', ' | append: gl
    endif
  endfor

  assign who_answer = ''
  if goal_labels != blank
    assign who_answer = 'Designed for ' | append: goal_labels | downcase | append: '.'
    if why != blank
      assign who_answer = who_answer | append: ' ' | append: why.first
    endif
  elsif why != blank
    assign who_answer = why.first
  endif

  assign wa_number = settings.whatsapp_number | remove: '+' | remove: ' ' | remove: '-'
  assign wa_msg = 'Hi Sahha Daily! 🌿 I have a question about ' | append: product.title | url_encode
-%}

<section class="sahha-faq color-{{ section.settings.color_scheme }}">
  <div class="sahha-wide faq-wrap">
    <div class="faq-intro">
      {%- if section.settings.kicker != blank -%}<span class="sahha-kicker no-line">{{ section.settings.kicker | escape }}</span>{%- endif -%}
      <h2 class="sahha-h-lg faq-h">{{ section.settings.heading }}</h2>
      {%- if section.settings.subtext != blank -%}<p class="sahha-lead">{{ section.settings.subtext }}</p>{%- endif -%}
      {%- if wa_number != blank -%}
        <a class="sahha-btn accent faq-help" href="https://wa.me/{{ wa_number }}?text={{ wa_msg }}" target="_blank" rel="noopener">
          <span>
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
            {{ section.settings.help_label | default: 'Ask about this product' }}
          </span>
        </a>
      {%- endif -%}
    </div>

    <div class="pfaq">
      {%- assign opened = false -%}

      {%- if how != blank -%}
        <details class="faq-item"{% unless opened %} open{% endunless %}>
          <summary>How do I take {{ short_title }}?<span class="pm" aria-hidden="true">+</span></summary>
          <div class="faq-a">{{ how | newline_to_br }}</div>
        </details>
        {%- assign opened = true -%}
      {%- endif -%}

      {%- if ingredients != blank -%}
        <details class="faq-item"{% unless opened %} open{% endunless %}>
          <summary>What&rsquo;s inside?<span class="pm" aria-hidden="true">+</span></summary>
          <div class="faq-a">{{ ingredients | newline_to_br }}</div>
        </details>
        {%- assign opened = true -%}
      {%- endif -%}

      {%- if who_answer != blank -%}
        <details class="faq-item"{% unless opened %} open{% endunless %}>
          <summary>Who is it for?<span class="pm" aria-hidden="true">+</span></summary>
          <div class="faq-a">{{ who_answer }}</div>
        </details>
        {%- assign opened = true -%}
      {%- endif -%}

      {%- if safety != blank -%}
        <details class="faq-item"{% unless opened %} open{% endunless %}>
          <summary>Is it safe to take?<span class="pm" aria-hidden="true">+</span></summary>
          <div class="faq-a">{{ safety | newline_to_br }}</div>
        </details>
        {%- assign opened = true -%}
      {%- endif -%}

      {%- if section.settings.order_answer != blank -%}
        <details class="faq-item"{% unless opened %} open{% endunless %}>
          <summary>How do I order and pay?<span class="pm" aria-hidden="true">+</span></summary>
          <div class="faq-a">{{ section.settings.order_answer }}</div>
        </details>
        {%- assign opened = true -%}
      {%- endif -%}

      {%- if section.settings.original_answer != blank -%}
        <details class="faq-item"{% unless opened %} open{% endunless %}>
          <summary>Are your products original?<span class="pm" aria-hidden="true">+</span></summary>
          <div class="faq-a">{{ section.settings.original_answer }}</div>
        </details>
        {%- assign opened = true -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
.sahha-faq { padding-block: clamp(48px, 7vw, 104px); background-color: rgb(var(--color-background)); }
.sahha-faq .sahha-wide { width: min(100% - 2 * var(--gutter), 1560px); margin-inline: auto; }
.faq-wrap { display: grid; grid-template-columns: 0.85fr 1.15fr; gap: clamp(28px, 4vw, 72px); align-items: start; }
.faq-intro .faq-h { margin: 14px 0 0; }
.faq-intro .sahha-lead { margin-top: 16px; }
.faq-help { margin-top: 26px; }

.pfaq { display: grid; grid-template-columns: 1fr; gap: 12px; max-width: 880px; }
.faq-item { border: 1px solid var(--line); border-radius: var(--r-md); background: var(--paper-2); overflow: hidden; transition: box-shadow .35s var(--ease); align-self: start; }
.faq-item[open] { box-shadow: var(--brand-shadow-sm); }
.faq-item summary { cursor: pointer; list-style: none; display: flex; align-items: center; justify-content: space-between; gap: 14px; padding: 18px 22px; font-weight: 700; font-size: 1.536rem; color: var(--green); }
.faq-item summary::-webkit-details-marker { display: none; }
.faq-item summary .pm { width: 26px; height: 26px; border-radius: 50%; border: 1px solid var(--line-2); display: grid; place-items: center; color: var(--accent); font-size: 1.6rem; line-height: 1; flex: none; transition: transform .3s var(--ease), background .3s, color .3s; }
.faq-item[open] summary .pm { transform: rotate(135deg); background: var(--accent); color: #fff; border-color: var(--accent); }
.faq-item .faq-a { padding: 0 22px 20px; color: var(--muted); font-size: 1.472rem; line-height: 1.65; }

@media (max-width: 980px) {
  .faq-wrap { grid-template-columns: 1fr; }
  .faq-intro { position: static; }
}
@media (prefers-reduced-motion: reduce) {
  .faq-item, .faq-item summary .pm { transition: none; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Sahha Product FAQ",
  "tag": "section",
  "class": "sahha-faq-section",
  "settings": [
    { "type": "paragraph", "content": "Builds 'Questions about this product' from the product's metafields (how to use, ingredients, safety, why use, goals) plus the two store-wide answers below." },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Good to know" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Questions about this <em>product</em>" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Anything we didn’t cover? Message us on WhatsApp and we reply fast." },
    { "type": "text", "id": "help_label", "label": "Help button label", "default": "Ask about this product" },
    { "type": "header", "content": "Store-wide answers" },
    { "type": "textarea", "id": "order_answer", "label": "How do I order and pay?", "default": "Add it to your basket and check out with Cash on Delivery — or send it to us on WhatsApp. Our team replies fast with delivery details for your area." },
    { "type": "textarea", "id": "original_answer", "label": "Are your products original?", "default": "Always. Every product is sourced directly from trusted European suppliers — verified originals only, never imitations." },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" }
  ],
  "presets": [{ "name": "Sahha Product FAQ" }]
}
{% endschema %}
