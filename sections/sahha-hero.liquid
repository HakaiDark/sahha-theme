{%- comment -%}
  Sahha Daily hero — ported 1:1 from the live site's <Hero> (.hx-* system in
  SahhaDaily/src/app/globals.css). Split copy + a mint/sage visual panel with a
  floating product and a rating pill. Ambient orbs, product rise, pill float and
  soft glow are CSS-only and gated behind prefers-reduced-motion.

  REM ×1.6: Dawn root = 10px, original = 16px, so every rem copied from the
  original is multiplied by 1.6 (px/vw left as-is). See memory design-port-sahha.

  If a "Rotate product images from" collection is set, the visual cross-fades
  through that collection's product images (matches the live carousel); otherwise
  it falls back to the single image / product / placeholder.
{%- endcomment -%}

{%- liquid
  assign rotate = section.settings.collection
  assign has_rotator = false
  if rotate != blank and rotate.products_count > 0
    assign has_rotator = true
  endif

  assign hero_image = section.settings.image
  if hero_image == blank and section.settings.product != blank
    assign hero_image = section.settings.product.featured_image
  endif
-%}

<section class="sahha-hx color-{{ section.settings.color_scheme }}" data-section-id="{{ section.id }}">
  <span class="sahha-hx__orb a" aria-hidden="true"></span>
  <span class="sahha-hx__orb b" aria-hidden="true"></span>

  <div class="sahha-hx__wrap sahha-hx__grid">
    <div class="sahha-hx__copy">
      {%- if section.settings.heading != blank -%}
        <h1 class="sahha-hx__title">{{ section.settings.heading }}</h1>
      {%- endif -%}

      <span class="sahha-hx__sep" aria-hidden="true"></span>

      {%- if section.settings.arabic_line != blank -%}
        <p class="sahha-hx__ar ar" dir="rtl">{{ section.settings.arabic_line }}</p>
      {%- endif -%}
      {%- if section.settings.tagline != blank -%}
        <p class="sahha-hx__tagline">{{ section.settings.tagline }}</p>
      {%- endif -%}
      {%- if section.settings.subtext != blank -%}
        <p class="sahha-lead sahha-hx__sub">{{ section.settings.subtext }}</p>
      {%- endif -%}

      <div class="sahha-hx__cta">
        {%- if section.settings.button_label != blank -%}
          <a class="sahha-btn accent" href="{{ section.settings.button_link | default: routes.all_products_collection_url }}">
            <span>{{ section.settings.button_label }}
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </a>
        {%- endif -%}
        {%- if section.settings.button_label_2 != blank -%}
          <a class="sahha-btn ghost" href="{{ section.settings.button_link_2 }}"><span>{{ section.settings.button_label_2 }}</span></a>
        {%- endif -%}
      </div>
    </div>

    <div class="sahha-hx__visual">
      <div class="sahha-hx__prod{% if has_rotator %} sahha-hx__rotator{% endif %}"{% if has_rotator %} data-hx-rotator="{{ section.id }}"{% endif %}>
        {%- if has_rotator -%}
          {%- for product in rotate.products limit: 10 -%}
            {%- if product.featured_image != blank -%}
              {%- liquid
                assign img_class = ''
                assign img_loading = 'lazy'
                if forloop.first
                  assign img_class = 'is-active'
                  assign img_loading = 'eager'
                endif
              -%}
              {{ product.featured_image | image_url: width: 900 | image_tag:
                loading: img_loading,
                class: img_class,
                sizes: '(min-width: 990px) 34vw, 70vw',
                widths: '300, 450, 600, 750, 900',
                alt: product.featured_image.alt | default: product.title | escape }}
            {%- endif -%}
          {%- endfor -%}
        {%- elsif hero_image != blank -%}
          {{ hero_image | image_url: width: 900 | image_tag:
            loading: 'eager',
            sizes: '(min-width: 990px) 34vw, 70vw',
            widths: '300, 450, 600, 750, 900',
            alt: hero_image.alt | default: section.settings.heading | escape }}
        {%- else -%}
          {{ 'product-apparel-1' | placeholder_svg_tag: 'sahha-hx__placeholder' }}
        {%- endif -%}
      </div>

      {%- if section.settings.rating_label != blank -%}
        <div class="sahha-hx__pill p1">
          <span class="ic">★</span>
          <span class="tx">
            <b>{{ section.settings.rating_label }}</b>
            <span>{{ section.settings.reviews_label }}</span>
          </span>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{%- if has_rotator -%}
  <script>
    (function () {
      var root = document.querySelector('[data-hx-rotator="{{ section.id }}"]');
      if (!root || root.dataset.bound) return;
      var imgs = root.querySelectorAll('img');
      if (imgs.length < 2) return;
      root.dataset.bound = '1';
      imgs[0].classList.add('is-active');
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      var i = 0;
      setInterval(function () {
        imgs[i].classList.remove('is-active');
        i = (i + 1) % imgs.length;
        imgs[i].classList.add('is-active');
      }, 4600);
    })();
  </script>
{%- endif -%}

{% stylesheet %}
.sahha-hx { position: relative; padding: clamp(48px,6vh,92px) 0 clamp(60px,8vw,110px); overflow: hidden; background-color: rgb(var(--color-background)); }
/* hero uses the original's wide wrap (1560px), not the 1360px site wrap */
.sahha-hx__wrap { width: min(100% - 2 * var(--gutter), 1560px); margin-inline: auto; }
.sahha-hx__grid { display: grid; grid-template-columns: 1.02fr 0.98fr; gap: clamp(32px,5vw,80px); align-items: center; }
.sahha-hx__copy { position: relative; z-index: 2; max-width: 600px; }

/* Title — Playfair 500, green by default; italic words go accent-orange */
.sahha-hx__title { font-family: var(--serif); font-weight: 500; font-size: clamp(4.64rem,5.6vw,8.96rem); line-height: 1.02; letter-spacing: -0.02em; color: var(--green); overflow-wrap: break-word; margin: 0; }
.sahha-hx__title em, .sahha-hx__title i, .sahha-hx__title .it { font-style: italic; color: var(--accent); }
.sahha-hx__title strong, .sahha-hx__title b { font-weight: 500; }

.sahha-hx__sep { display: block; width: 64px; height: 3px; border-radius: 999px; background: var(--sage); margin: 20px 0; }

.sahha-hx__ar { font-family: var(--arabic); direction: rtl; text-align: left; font-size: clamp(1.92rem,2vw,2.56rem); font-weight: 800; color: var(--green); margin: 18px 0 0; }
.sahha-hx__ar .o { color: var(--accent); }

.sahha-hx__tagline { margin: 10px 0 0; font-family: var(--serif); font-weight: 500; font-size: clamp(1.84rem,1.9vw,2.48rem); line-height: 1.1; letter-spacing: -0.01em; color: var(--green); }
.sahha-hx__tagline em, .sahha-hx__tagline i, .sahha-hx__tagline .it { font-style: italic; color: var(--accent); }

.sahha-hx__sub { margin: 22px 0 30px; max-width: 44ch; color: var(--ink-soft); }
.sahha-hx__cta { display: flex; flex-wrap: wrap; gap: 14px; align-items: center; }

/* Visual panel */
.sahha-hx__visual { position: relative; aspect-ratio: 1/1.04; border-radius: var(--r-xl); background: radial-gradient(120% 100% at 50% 30%, var(--tint-mint), var(--tint-sage) 78%); display: grid; place-items: center; overflow: hidden; box-shadow: var(--brand-shadow); perspective: 900px; }
.sahha-hx__prod { position: relative; z-index: 2; display: grid; width: 70%; filter: drop-shadow(0 40px 44px rgba(28,60,42,0.26)); animation: sahhaHxRise .9s var(--ease) both; }
.sahha-hx__prod > img, .sahha-hx__prod > svg { grid-area: 1 / 1; width: 100%; height: auto; display: block; }
.sahha-hx__prod::after { content: ""; position: absolute; inset: 10% 14% 6%; background: radial-gradient(circle at 50% 40%, rgba(255,255,255,0.6), transparent 66%); filter: blur(20px); z-index: -1; }
/* cross-fade carousel */
.sahha-hx__rotator > img { opacity: 0; transition: opacity 1s var(--ease); }
.sahha-hx__rotator > img.is-active { opacity: 1; }

/* Rating pill */
.sahha-hx__pill { position: absolute; z-index: 3; top: 12%; left: -4%; background: var(--paper-2); border: 1px solid var(--line); border-radius: var(--r-pill); padding: 12px 18px; box-shadow: var(--brand-shadow-sm); display: flex; align-items: center; gap: 10px; animation: sahhaHxPill 5s ease-in-out infinite; }
.sahha-hx__pill .ic { width: 34px; height: 34px; border-radius: 50%; display: grid; place-items: center; background: var(--tint-peach); color: var(--accent-deep); flex: none; }
.sahha-hx__pill .tx { display: flex; flex-direction: column; line-height: 1.2; }
.sahha-hx__pill .tx b { font-size: 1.344rem; color: var(--ink); white-space: nowrap; }
.sahha-hx__pill .tx span { font-size: 1.152rem; color: var(--muted); white-space: nowrap; }

/* Ambient orbs */
.sahha-hx__orb { position: absolute; border-radius: 50%; filter: blur(46px); opacity: 0.5; z-index: 0; pointer-events: none; animation: sahhaHxOrb 16s ease-in-out infinite; }
.sahha-hx__orb.a { width: 380px; height: 380px; background: radial-gradient(circle, rgba(167,196,154,0.7), transparent 70%); top: -8%; left: -6%; }
.sahha-hx__orb.b { width: 320px; height: 320px; background: radial-gradient(circle, rgba(224,116,74,0.32), transparent 70%); bottom: -10%; right: 6%; animation-delay: -6s; }

@keyframes sahhaHxRise { from { opacity: 0; transform: translateY(22px) scale(.86); } to { opacity: 1; transform: none; } }
@keyframes sahhaHxOrb { 0%,100% { transform: translate(0,0) scale(1); } 50% { transform: translate(24px,-30px) scale(1.08); } }
@keyframes sahhaHxPill { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-9px); } }

@media (max-width: 989px) {
  .sahha-hx__grid { grid-template-columns: 1fr; gap: 30px; }
  .sahha-hx__visual { max-width: 520px; margin-inline: auto; width: 100%; }
  .sahha-hx__pill.p1 { left: 2%; }
}
@media (max-width: 600px) {
  .sahha-hx { padding: clamp(6px,1.8vh,18px) 0 clamp(40px,7vw,72px); }
  .sahha-hx__visual { max-width: 420px; }
  .sahha-hx__pill { padding: 9px 13px; }
  .sahha-hx__pill .tx b { font-size: 1.248rem; } .sahha-hx__pill .tx span { font-size: 1.056rem; }
  .sahha-hx__cta { gap: 10px; }
  .sahha-hx__cta .sahha-btn { flex: 1; min-width: 0; justify-content: center; }
}
@media (prefers-reduced-motion: reduce) {
  .sahha-hx__prod, .sahha-hx__orb, .sahha-hx__pill { animation: none; }
  .sahha-hx__rotator > img { transition: none; }
  .sahha-hx__prod::after { display: none; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Sahha Hero",
  "tag": "section",
  "class": "sahha-hero-section",
  "settings": [
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "info": "Italicise a word to colour it orange.", "default": "Premium Wellness <em>Supplements</em>" },
    { "type": "text", "id": "arabic_line", "label": "Arabic line", "default": "صحتك بالديني" },
    { "type": "inline_richtext", "id": "tagline", "label": "Tagline", "default": "Daily support, <em>better you</em> 🌿" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Premium wellness supplements for energy, beauty, immunity and active living, sourced from Europe and delivered to your door." },
    { "type": "header", "content": "Visual" },
    { "type": "collection", "id": "collection", "label": "Rotate product images from", "info": "Cross-fades through this collection's product images (matches the live hero). Leave empty to use a single image below." },
    { "type": "image_picker", "id": "image", "label": "Hero image" },
    { "type": "product", "id": "product", "label": "…or pull image from a product" },
    { "type": "text", "id": "rating_label", "label": "Rating pill — title", "default": "4.8 rating" },
    { "type": "text", "id": "reviews_label", "label": "Rating pill — subtitle", "default": "1,200+ reviews" },
    { "type": "header", "content": "Buttons" },
    { "type": "text", "id": "button_label", "label": "Primary button label", "default": "Shop products" },
    { "type": "url", "id": "button_link", "label": "Primary button link" },
    { "type": "text", "id": "button_label_2", "label": "Secondary button label", "default": "Talk to an expert" },
    { "type": "url", "id": "button_link_2", "label": "Secondary button link" },
    { "type": "header", "content": "Appearance" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" }
  ],
  "presets": [{ "name": "Sahha Hero" }]
}
{% endschema %}
